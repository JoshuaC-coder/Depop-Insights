{
  "manifest_version": 3,
  "name": "Depop Insights",
  "version": "0.1.0",
  "description": "Resale pricing and listing insights for Depop listings.",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "permissions": ["activeTab", "storage", "tabs"],
  "host_permissions": [
    "https://www.depop.com/*",
    "https://depop.com/*",
    "http://127.0.0.1:8000/*",
    "http://localhost:8000/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Depop Insights",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://www.depop.com/*", "https://depop.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
